NODE_ENV=development
API_PORT=5000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql://loadtest:change-me@localhost:5432/loadtesting
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=15m
WORKER_QUEUE_NAME=load-test-jobs
WORKER_CAPACITY=500
MAX_VIRTUAL_USERS_PER_RUN=10000
MAX_TEST_DURATION_SECONDS=3600
TARGET_VERIFICATION_REQUIRED=true
TARGET_REQUEST_TIMEOUT_MS=10000
DATABASE_SSL=false
